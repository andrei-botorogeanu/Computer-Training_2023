Pointers (adrese, referinta)
--------------------------

//am declarat o variabila de tip intreg
int v;

v = 7;

//am declarat o variabila pointer catre tip integer
int *v;

int a = 7;
//false
v = a;

//true 
v = &a; //adresa variabilei de tip intreg

cout<<*v;

& -operatorul 

int arr = [1,2,3,4,5,6,8]

int *p;
p = &arr;

cout<<p[0]

